<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="KLALIK.Views.ModeratorDashboard">
  <DockPanel>
    <Border DockPanel.Dock="Top"
            Padding="12,10"
            Background="#FF313244">
      <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
        <TextBlock Text="Панель модератора"
                   VerticalAlignment="Center"
                   Foreground="#FFCDD6F4"
                   FontSize="14"
                   FontWeight="SemiBold" />
        <Button x:Name="LogoutButton"
                Grid.Column="1"
                Content="Выйти"
                MinWidth="100" />
      </Grid>
    </Border>
    <TabControl Margin="12">
      <TabItem Header="Услуги и коллекции">
        <Grid ColumnDefinitions="280,*" Margin="0,8,0,0" ColumnSpacing="12">
          <DockPanel>
            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
              <Button x:Name="NewServiceButton" Content="Новая услуга" MinWidth="120" />
              <Button x:Name="SaveServiceButton" Content="Сохранить" MinWidth="100" />
            </StackPanel>
            <ListBox x:Name="ServicesListBox" />
          </DockPanel>
          <ScrollViewer Grid.Column="1">
            <StackPanel Spacing="10">
              <TextBlock Text="Редактирование услуги" Foreground="#FFBAC2DE" FontWeight="SemiBold" />
              <TextBox x:Name="ServiceNameBox" PlaceholderText="Название" />
              <TextBox x:Name="ServiceDescBox"
                       PlaceholderText="Описание"
                       AcceptsReturn="True"
                       Height="80" />
              <TextBox x:Name="ServicePriceBox" PlaceholderText="Цена (₽)" />
              <ComboBox x:Name="ServiceDirectionCombo" PlaceholderText="Коллекция / направление" />
              <ComboBox x:Name="ServiceCategoryCombo" PlaceholderText="Категория" />
              <CheckBox x:Name="ServiceHolidayCheck" Content="Связано с праздником" />
              <TextBlock x:Name="ServiceUpdatedText" Foreground="#FFA6ADC8" FontSize="12" />
            </StackPanel>
          </ScrollViewer>
        </Grid>
      </TabItem>
      <TabItem Header="Мастера и услуги">
        <Grid RowDefinitions="Auto,*" Margin="0,8,0,0" RowSpacing="10">
          <StackPanel Orientation="Horizontal" Spacing="10">
            <TextBlock Text="Мастер:" VerticalAlignment="Center" Foreground="#FFBAC2DE" />
            <ComboBox x:Name="MastersCombo" MinWidth="240" PlaceholderText="Выберите мастера" />
            <Button x:Name="SaveLinksButton" Content="Сохранить привязки" MinWidth="160" />
          </StackPanel>
          <ScrollViewer Grid.Row="1">
            <StackPanel x:Name="MasterServicesPanel" Spacing="6" />
          </ScrollViewer>
        </Grid>
      </TabItem>
      <TabItem Header="Квалификация">
        <Grid RowDefinitions="Auto,*" Margin="0,8,0,0" RowSpacing="10">
          <TextBlock Text="Заявки мастеров"
                     Foreground="#FFBAC2DE"
                     FontWeight="SemiBold" />
          <ListBox x:Name="QualificationList" Grid.Row="1" />
        </Grid>
      </TabItem>
      <TabItem Header="Отзывы">
        <ScrollViewer Margin="0,8,0,0">
          <StackPanel x:Name="ModeratorReviewsPanel" Spacing="12" />
        </ScrollViewer>
      </TabItem>
    </TabControl>
  </DockPanel>
</UserControl>
