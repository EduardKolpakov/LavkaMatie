<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="KLALIK.Views.RegisterView">
  <ScrollViewer>
    <StackPanel Margin="32" Spacing="14" MaxWidth="480" HorizontalAlignment="Left">
      <TextBlock Text="Регистрация"
                 FontSize="24"
                 FontWeight="SemiBold"
                 Foreground="#FFCDD6F4" />
      <TextBox x:Name="DisplayNameBox"
               PlaceholderText="Имя" />
      <TextBox x:Name="EmailBox"
               PlaceholderText="Email" />
      <TextBox x:Name="PasswordBox"
               PlaceholderText="Пароль (не короче 6 символов)"
               PasswordChar="•" />
      <Button x:Name="RegisterButton"
              Content="Создать аккаунт"
              HorizontalAlignment="Stretch"
              HorizontalContentAlignment="Center" />
      <Button x:Name="GoToLoginButton"
              Content="Уже есть аккаунт? Войти"
              HorizontalAlignment="Stretch"
              HorizontalContentAlignment="Center"
              Background="Transparent"
              Foreground="#FF89B4FA"
              BorderThickness="0" />
      <TextBlock x:Name="ErrorText"
                 Foreground="#FFF38BA8"
                 TextWrapping="Wrap"
                 IsVisible="False" />
    </StackPanel>
  </ScrollViewer>
</UserControl>
